<?xml version="1.0" encoding="UTF-8" ?>

<container
        xmlns="http://symfony.com/schema/dic/services"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <imports>
        <import resource="services/**" />
    </imports>

    <services>
        <defaults autowire="true" autoconfigure="true" />
        <service id="FraudLabsPro\SyliusFraudLabsProPlugin\EventSubscriber\FraudCheckSubscriber">
            <argument type="service" id="router" />
            <argument type="service" id="request_stack" />
            <argument type="service" id="http_client" />
            <argument type="service" id="logger" />
            <tag name="kernel.event_subscriber" />
        </service>
        <service id="FraudLabsPro\SyliusFraudLabsProPlugin\Form\Extension\ChannelTypeExtension">
            <argument type="service" id="doctrine.orm.entity_manager" />
            <tag name="form.type_extension" extended-type="Sylius\Bundle\ChannelBundle\Form\Type\ChannelType" />
        </service>
    </services>
</container>
